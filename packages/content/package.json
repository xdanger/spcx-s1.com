{
  "name": "@spcx/content",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./manifest": "./src/manifest.ts"
  },
  "bin": {
    "validate-content": "./bin/validate.ts"
  },
  "scripts": {
    "build": "tsc --noEmit && node --import tsx bin/validate.ts --phase=4",
    "validate": "node --import tsx bin/validate.ts --phase=4",
    "validate:phase1": "node --import tsx bin/validate.ts --phase=1",
    "audit-zh": "node --import tsx bin/audit-zh.ts",
    "refresh-manifest": "node --import tsx bin/refresh-manifest.ts",
    "test": "vitest run",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --no-error-on-unmatched-pattern --fix"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
